# Copy to .env for local dev. Add same keys as GitHub Actions secrets for Pages builds.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Admin PIN is stored in Supabase (app_settings) — see supabase/migration_admin.sql
# Optional fallback only if DB row missing:
# VITE_ADMIN_PIN=

# One-time schema apply (npm run db:apply) — pick ONE approach:
# A) Paste "Session pooler" URI from Supabase → Settings → Database:
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# B) Or password + AWS region (eu-central-1, us-east-1, …):
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-central-1
